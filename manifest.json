{
  "manifest_version": 3,
  "name": "Doc Nav Extractor",
  "version": "1.1",
  "description": "ドキュメントサイトのサイドバーナビゲーションを階層構造で抽出",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://developers.meta.com/*",
    "https://dev.epicgames.com/*",
    "https://docs.unity3d.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Doc Nav Extractor"
  },
  "content_scripts": [
    {
      "matches": [
        "https://developers.meta.com/horizon/documentation/unity/*",
        "https://developers.meta.com/horizon/develop/unity/"
      ],
      "js": ["content-meta.js"]
    },
    {
      "matches": [
        "https://dev.epicgames.com/documentation/*"
      ],
      "js": ["content-epic.js"]
    },
    {
      "matches": [
        "https://docs.unity3d.com/Manual/*",
        "https://docs.unity3d.com/*/Documentation/Manual/*"
      ],
      "js": ["content-unity.js"]
    },
    {
      "matches": [
        "https://docs.unity3d.com/Packages/*"
      ],
      "js": ["content-unity-packages.js"]
    }
  ]
}
